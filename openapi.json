    "/products/search": {
      "get": {
        "tags": ["商品"],
        "summary": "商品搜索",
        "description": "按关键词搜索商品，支持多维度筛选和排序",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            },
