            "description": "每页数量，最大100条",
            "example": 20
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/analytics/events": {
      "post": {
        "tags": ["分析"],
        "summary": "上报用户行为",
        "description": "上报用户操作事件用于数据分析",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "title": "用户事件上报请求",
                "description": "上报用户操作事件，用于数据分析和推荐系统",
                "properties": {
                  "event_type": {
                    "type": "string",
                    "description": "事件类型",
                    "enum": ["search", "product_click", "add_favorite", "remove_favorite", "alert_set", "purchase_redirect"],
                    "example": "search"
                  },
                  "product_id": {
                    "type": "string",
                    "description": "商品ID（仅在与商品相关的事件时使用）",
                    "example": "SKU20250315001",
                    "maxLength": 32,
                    "nullable": true
                  },
                  "platform": {
                    "type": "string",
                    "description": "平台名称（仅在platform_click事件时使用）",
                    "example": "taobao",
                    "maxLength": 32,
                    "nullable": true
                  },
                  "timestamp": {
                    "type": "string",
                    "format": "date-time",
                    "description": "事件发生的时间（ISO 8601格式）",
                    "example": "2025-03-24T10:30:00Z"
                  },
                  "metadata": {
                    "type": "object",
                    "description": "附加元数据，用于存储特殊事件信息。如search事件可包含keyword字段",
                    "example": {"keyword": "iPhone 15", "search_platform": "ycg"},
                    "nullable": true,
                    "additionalProperties": true
                  }
                },
                "required": ["event_type", "timestamp"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "上报成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}
