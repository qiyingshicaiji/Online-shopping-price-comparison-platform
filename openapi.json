            "example": "iPhone 15 Pro Max"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "页码，从1开始",
            "example": 1
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 100
            },
            "description": "每页数量，最大100条",
            "example": 20
          },
          {
            "name": "category_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "description": "商品分类ID（可选），用于按类目筛选。如10001=电子产品，10002=服装等",
            "example": 10001
          },
          {
            "name": "min_price",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": 0
            },
            "description": "最低价格（单位：元），用于价格区间筛选",
            "example": 5000.00
          },
          {
            "name": "max_price",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": 0
            },
            "description": "最高价格（单位：元），用于价格区间筛选",
            "example": 9999.00
          },
          {
            "name": "platform",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "平台筛选，多个平台用英文逗号分隔。可选值：taobao,jingdong,pinduoduo,amazon,other",
